# ============================================================================
# Last-Mile Delivery Tracker — Environment Variables
# Copy this file to `.env` and fill in real values. `.env` is git-ignored.
# ============================================================================

# ----------------------------------------------------------------------------
# DATABASE (Supabase Postgres, used by Prisma)
# In the Supabase dashboard: Project Settings → Database → Connection string.
#   • DATABASE_URL  = "Transaction" pooler (port 6543) — used by the app at runtime.
#                     Append ?pgbouncer=true&connection_limit=1
#   • DIRECT_URL    = "Session"/Direct connection (port 5432) — used for migrations.
# ----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# ----------------------------------------------------------------------------
# SUPABASE AUTH & CLIENT
# Supabase dashboard → Project Settings → API.
#   • NEXT_PUBLIC_* values are safe to expose to the browser.
#   • SERVICE_ROLE_KEY is SERVER-ONLY (used by the seed script / admin actions). Never expose it.
# ----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-secret-key"

# ----------------------------------------------------------------------------
# EMAIL (SMTP via Nodemailer) — primary notification channel
# Any free SMTP works. For Gmail: create an App Password (Google Account → Security
# → 2-Step Verification → App passwords) and use it as SMTP_PASSWORD.
# ----------------------------------------------------------------------------
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"                 # true for port 465, false for 587 (STARTTLS)
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM="Last-Mile Tracker <your-email@gmail.com>"

# ----------------------------------------------------------------------------
# NOTIFICATIONS
#   SMS_PROVIDER: "mock" logs SMS + records a Notification row (default; demo works
#   with no paid SMS). Swap to a real provider later behind the same interface.
# ----------------------------------------------------------------------------
SMS_PROVIDER="mock"

# ----------------------------------------------------------------------------
# APP
# ----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ----------------------------------------------------------------------------
# AI FEATURES (stretch, optional — degrade gracefully when disabled)
#   AI_FEATURES_ENABLED=false keeps all AI off the critical path.
# ----------------------------------------------------------------------------
AI_FEATURES_ENABLED="false"
ANTHROPIC_API_KEY=""
